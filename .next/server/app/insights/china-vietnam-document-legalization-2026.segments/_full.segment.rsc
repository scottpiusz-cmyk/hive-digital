16:["$","p","p-6",{"className":"text-hive-muted leading-relaxed mb-5","children":["Until the Apostille Convention enters force in September 2026, ",["$","strong","1",{"className":"text-white","children":"documents issued in China"}]," that are intended for legal use in Vietnam must traverse a four-step consular legalization process. This chain cannot be completed within Vietnam — all steps must be executed in China before document transfer."]}]
