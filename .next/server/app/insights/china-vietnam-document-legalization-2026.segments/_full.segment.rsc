x items-center gap-1.5","children":[["$","$L13",null,{"ref":"$undefined","iconNode":[["circle",{"cx":"12","cy":"12","r":"10","key":"1mglay"}],["path",{"d":"M12 6v6l4 2","key":"mmk7yg"}]],"className":"lucide-clock w-4 h-4"}],"8 min read"]}]]}]]}],["$","div",null,{"className":"h-px bg-hive-border mb-10"}],["$","div",null,{"className":"prose-hive","children":[["$","h2","h2-0",{"className":"text-2xl font-bold text-white mt-12 mb-5 uppercase tracking-tight","children":"The Regulatory Inflection Point"}],["$","p","p-1",{"className":"text-hive-muted leading-relaxed mb-5","children":["Vietnam's document authentication landscape is undergoing its most significant transformation in decades. On December 31, 2025, Vietnam formally acceded to the Hague Convention of 1961 Abolishing the Requirement of Legalization for Foreign Public Documents — the Apostille Convention — with the treaty entering into force on ",["$","strong","1",{"className":"text-white","children":"September 11, 2026"}],". Concurrently, ",["$","strong","3",{"className":"text-white","children":"Decree 219/2025/ND-CP"}]," (effective August 7, 2025) has replaced the previous Decree 152/2020/ND-CP, streamlining work permit procedures while maintaining rigorous document compliance standards."]}],["$","p","p-2",{"className":"text-hive-text font-semibold mb-2 mt-6","children":"Scope note: This guide specifically addresses Chinese-originating documents — that is, documents issued in China (degrees, marriage certificates, business licenses, etc.) that require legalization for use in Vietnam. Documents originating from the United States, Canada, the UK, or any other country must be authenticated through that country's own apostille or consular legalization process before they can be used in Vietnam. See the section \"Third-Country Documents: US, Canada & Beyond\" below for details."}],["$","p","p-3",{"className":"text-hive-muted leading-relaxed mb-5","children":["For HR teams and compliance officers managing employee mobility between China and Vietnam, these concurrent changes demand a strategic reassessment of document processing workflows. This guide provides a technical deep-dive into the current consular legalization chain for Chinese-originating documents, the forthcoming apostille transition, and actionable compliance frameworks for 2026."]}],"$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c","$L4d","$L4e","$L4f","$L50","$L51","$L52","$L53","$L54","$L55","$L56","$L57","$L58","$L59","$L5a","$L5b","$L5c","$L5d","$L5e","$L5f","$L60","$L61","$L62","$L63","$L64","$L65","$L66","$L67","$L68","$L69","$L6a","$L6b","$L6c","$L6d","$L6e","$L6f","$L70","$L71","$L72","$L73","$L74","$L75","$L76","$L77","$L78","$L79","$L7a","$L7b","$L7c","$L7d","$L7e","$L7f","$L80","$L81","$L82","$L83","$L84","$L85","$L86","$L87"]}],"$L88"]}],"$L89"]}]]}]}]
