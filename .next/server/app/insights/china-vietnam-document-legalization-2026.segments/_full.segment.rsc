1b:["$","p","p-14",{"className":"text-hive-text font-semibold mb-2 mt-6","children":"Critical note: Civil documents with foreign elements require pre-notarization by a Chinese foreign affairs agency (外事办公室) or a notary in Beijing before proceeding to consular authentication."}]
