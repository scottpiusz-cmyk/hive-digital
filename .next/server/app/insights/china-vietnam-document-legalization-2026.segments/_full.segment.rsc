43:["$","p","p-54",{"className":"text-hive-text font-semibold mb-2 mt-6","children":"Rule of thumb: The country named on the document is the country where authentication must occur. A diploma from the University of Toronto is authenticated in Canada. A degree from Peking University is authenticated in China. An FBI check is authenticated in the United States."}]
